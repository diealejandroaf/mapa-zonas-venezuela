# Copia a .env y completa con tus valores.

# --- Base de datos (Neon Postgres) ---
# DATABASE_URL: cadena "pooled" (con -pooler en el host). La usa la app en runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# DIRECT_URL: cadena directa (sin -pooler). La usan `prisma db push` y el seed.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# --- Moderación ---
# Token para los endpoints /api/admin/* (cámbialo por algo largo y secreto).
ADMIN_TOKEN="cambia-esto-por-un-token-secreto"
